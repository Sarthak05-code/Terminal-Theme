{
  "name": "Hacker Terminal",
  "type": "dark",
  "colors": {
    "editor.background": "#0d0f12",
    "editor.foreground": "#c9d1d9",
    "editor.lineHighlightBackground": "#15181c",
    "editor.selectionBackground": "#2f9e6e40",
    "editorCursor.foreground": "#2f9e6e",
    "editorLineNumber.foreground": "#3a3f47",
    "editorLineNumber.activeForeground": "#2f9e6e",
    "editorIndentGuide.background1": "#1a1d22",
    "editorIndentGuide.activeBackground1": "#2a2f36",

    "activityBar.background": "#0a0c0e",
    "activityBar.foreground": "#2f9e6e",
    "activityBarBadge.background": "#2f9e6e",
    "activityBarBadge.foreground": "#0d0f12",

    "sideBar.background": "#0a0c0e",
    "sideBar.foreground": "#9ba3ad",
    "sideBarTitle.foreground": "#2f9e6e",
    "sideBarSectionHeader.background": "#0d0f12",

    "statusBar.background": "#0a0c0e",
    "statusBar.foreground": "#2f9e6e",
    "statusBar.noFolderBackground": "#0a0c0e",
    "statusBar.debuggingBackground": "#2f9e6e",
    "statusBar.debuggingForeground": "#0d0f12",

    "titleBar.activeBackground": "#0a0c0e",
    "titleBar.activeForeground": "#2f9e6e",
    "titleBar.inactiveBackground": "#0a0c0e",
    "titleBar.inactiveForeground": "#5a626c",

    "tab.activeBackground": "#15181c",
    "tab.activeForeground": "#2f9e6e",
    "tab.inactiveBackground": "#0a0c0e",
    "tab.inactiveForeground": "#5a626c",
    "tab.border": "#0d0f12",

    "terminal.background": "#0d0f12",
    "terminal.foreground": "#c9d1d9",
    "terminal.ansiGreen": "#2f9e6e",
    "terminal.ansiBrightGreen": "#4ab98a",
    "terminalCursor.foreground": "#2f9e6e",

    "panel.background": "#0a0c0e",
    "panel.border": "#1a1d22",

    "input.background": "#15181c",
    "input.foreground": "#c9d1d9",
    "input.border": "#2a2f36",
    "focusBorder": "#2f9e6e",

    "button.background": "#2f9e6e",
    "button.foreground": "#0d0f12",
    "button.hoverBackground": "#4ab98a",

    "scrollbarSlider.background": "#2f9e6e33",
    "scrollbarSlider.hoverBackground": "#2f9e6e55",

    "badge.background": "#2f9e6e",
    "badge.foreground": "#0d0f12",

    "minimap.background": "#0a0c0e",
    "minimapSlider.background": "#2f9e6e22",
    "minimapSlider.hoverBackground": "#2f9e6e44",
    "minimapSlider.activeBackground": "#2f9e6e66",

    "editorBracketHighlight.foreground1": "#2f9e6e",
    "editorBracketHighlight.foreground2": "#e3b341",
    "editorBracketHighlight.foreground3": "#d2a8ff",
    "editorBracketHighlight.foreground4": "#79c0ff",
    "editorBracketPairGuide.activeBackground1": "#2f9e6e88",

    "editorHoverWidget.background": "#15181c",
    "editorHoverWidget.border": "#2a2f36",
    "editorHoverWidget.foreground": "#c9d1d9",

    "editorSuggestWidget.background": "#15181c",
    "editorSuggestWidget.border": "#2a2f36",
    "editorSuggestWidget.foreground": "#c9d1d9",
    "editorSuggestWidget.selectedBackground": "#2f9e6e22",
    "editorSuggestWidget.highlightForeground": "#2f9e6e",

    "peekView.border": "#2f9e6e",
    "peekViewEditor.background": "#0a0c0e",
    "peekViewResult.background": "#0a0c0e",
    "peekViewTitle.background": "#15181c",
    "peekViewTitleLabel.foreground": "#2f9e6e",
    "peekViewResult.selectionBackground": "#2f9e6e33",

    "dropdown.background": "#15181c",
    "dropdown.foreground": "#c9d1d9",
    "dropdown.border": "#2a2f36",

    "breadcrumb.background": "#0a0c0e",
    "breadcrumb.foreground": "#5a626c",
    "breadcrumb.activeSelectionForeground": "#2f9e6e",

    "gitDecoration.addedResourceForeground": "#4ab98a",
    "gitDecoration.modifiedResourceForeground": "#e3b341",
    "gitDecoration.deletedResourceForeground": "#e0666b",
    "gitDecoration.untrackedResourceForeground": "#79c0ff",

    "diffEditor.insertedTextBackground": "#2f9e6e22",
    "diffEditor.removedTextBackground": "#e0666b22",

    "notifications.background": "#15181c",
    "notifications.foreground": "#c9d1d9",
    "notificationCenterHeader.background": "#0a0c0e"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#5a626c", "fontStyle": "italic" }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": { "foreground": "#e0666b", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword", "keyword.other", "keyword.operator.new"],
      "settings": { "foreground": "#2f9e6e", "fontStyle": "bold" }
    },
    {
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#2f9e6e" }
    },
    {
      "scope": [
        "storage.modifier.const",
        "storage.type.const",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#4ab98a", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#e3b341" }
    },
    {
      "scope": [
        "string.template",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#f0d273" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#e0666b" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#79c0ff" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "#d2a8ff" }
    },
    {
      "scope": ["entity.name.function.decorator", "meta.decorator"],
      "settings": { "foreground": "#f0a8d0", "fontStyle": "italic" }
    },
    {
      "scope": ["variable", "variable.parameter"],
      "settings": { "foreground": "#c9d1d9" }
    },
    {
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#79c0ff", "fontStyle": "italic" }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class"],
      "settings": { "foreground": "#4ab98a" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#9ba3ad" }
    },
    {
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#9ba3ad" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#2f9e6e" }
    },
    {
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#5a626c" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#d2a8ff" }
    }
  ]
}
